<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DantePanda - Authorization</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&display=swap');

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Outfit', sans-serif;
            background: #0a0a0a;
            color: #ffffff;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .bg-glow {
            position: fixed;
            top: -30%;
            right: -20%;
            width: 60vw;
            height: 60vw;
            background: radial-gradient(circle, rgba(37, 244, 238, 0.1) 0%, transparent 70%);
            pointer-events: none;
        }

        .container {
            position: relative;
            z-index: 1;
            text-align: center;
            max-width: 500px;
            padding: 2rem;
        }

        .logo {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -1px;
            margin-bottom: 2rem;
            background: linear-gradient(135deg, #fe2c55, #25f4ee);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .card {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            padding: 3rem 2.5rem;
            backdrop-filter: blur(20px);
        }

        .spinner {
            width: 48px;
            height: 48px;
            border: 3px solid rgba(255, 255, 255, 0.1);
            border-top-color: #25f4ee;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 0 auto 1.5rem;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .status-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        h2 {
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 0.8rem;
        }

        p {
            color: #888;
            line-height: 1.6;
            font-size: 0.9rem;
        }

        .code-box {
            margin-top: 1.5rem;
            padding: 1rem;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            font-family: monospace;
            font-size: 0.8rem;
            color: #25f4ee;
            word-break: break-all;
            text-align: left;
        }

        .code-label {
            font-size: 0.7rem;
            color: #555;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 0.5rem;
            font-family: 'Outfit', sans-serif;
        }

        .error-card h2 { color: #fe2c55; }

        .back-link {
            display: inline-block;
            margin-top: 1.5rem;
            color: #25f4ee;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .back-link:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="bg-glow"></div>

    <div class="container">
        <div class="logo">DantePanda</div>

        <div class="card" id="loadingCard">
            <div class="spinner"></div>
            <h2>Processing Authorization...</h2>
            <p>Please wait while we connect your TikTok account.</p>
        </div>

        <div class="card" id="successCard" style="display:none;">
            <div class="status-icon">✅</div>
            <h2>TikTok Connected!</h2>
            <p>Your TikTok account has been successfully authorized. The authorization code has been received.</p>
            <div class="code-box">
                <div class="code-label">Authorization Code</div>
                <div id="authCode"></div>
            </div>
            <a href="index.html" class="back-link">← Back to Dashboard</a>
        </div>

        <div class="card error-card" id="errorCard" style="display:none;">
            <div class="status-icon">❌</div>
            <h2>Authorization Failed</h2>
            <p id="errorMsg">Something went wrong during authorization.</p>
            <a href="index.html" class="back-link">← Try Again</a>
        </div>
    </div>

    <script>
        window.addEventListener('load', function() {
            const params = new URLSearchParams(window.location.search);
            const code = params.get('code');
            const error = params.get('error');
            const errorDescription = params.get('error_description');

            setTimeout(function() {
                document.getElementById('loadingCard').style.display = 'none';

                if (code) {
                    document.getElementById('authCode').textContent = code;
                    document.getElementById('successCard').style.display = 'block';
                } else if (error) {
                    document.getElementById('errorMsg').textContent =
                        errorDescription || 'Authorization was denied or failed. Error: ' + error;
                    document.getElementById('errorCard').style.display = 'block';
                } else {
                    document.getElementById('errorMsg').textContent =
                        'No authorization code received. Please try connecting again.';
                    document.getElementById('errorCard').style.display = 'block';
                }
            }, 1500);
        });
    </script>
</body>
</html>
